FROM python:3.11-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    flask \
    diffusers \
    accelerate \
    transformers \
    torch \
    torchvision \
    --extra-index-url https://download.pytorch.org/whl/cpu

COPY scripts/image_server.py .

EXPOSE 7860

CMD ["python", "image_server.py", "--host", "0.0.0.0", "--port", "7860"]
